animation := import("animation")
ai := import("ai")

followState := {
    enter: func(state) {
        animation.set("run")
    },

    update: func(state) {
        ai.move_towards_player()
        ai.face_player()

        if ai.lost_player() {
            state["next_state"] = "idle"
            return
        }

        if ai.in_attack_range() {
            state["next_state"] = "attack"
        }
    },

    exit: func(state) {}
}
