animation := import("animation")
ai := import("ai")
audio := import("audio")


followState := {
    enter: func(state) {
        animation.set("run")
    },

    update: func(state) {
        if ai.lost_player() {
            state["next_state"] = "idle"
            return
        }

        state["next_state"] = "ready"
    },

    exit: func(state) {}
}
