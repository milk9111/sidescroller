animation := import("animation")
audio := import("audio")
physics := import("physics")
hazard := import("hazard")

deathState := {
    enter: func(state) {
        animation.set("death")
        audio.play("death")
        hazard.disable()
    },

    update: func(state) {
        physics.stop_xy()
    },

    exit: func(state) {}
}
